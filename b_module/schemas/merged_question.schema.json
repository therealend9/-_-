{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MergedQuestion",
  "type": "object",
  "required": ["merge_group_id", "question_no", "from_pages", "merged_text", "merge_confidence", "needs_review"],
  "properties": {
    "file_id": { "type": "string" },
    "route_type": {
      "type": "string",
      "enum": ["uniform_exam", "free_layout_homework"]
    },
    "merge_group_id": { "type": "string" },
    "question_no": { "type": "string" },
    "from_pages": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 }
    },
    "merged_text": { "type": "string" },
    "merge_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "needs_review": { "type": "boolean" },
    "source_candidate_indexes": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    },
    "merge_evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "issue_flags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
