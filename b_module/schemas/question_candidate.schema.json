{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuestionCandidate",
  "type": "object",
  "required": ["question_no", "page_no", "block_ids", "text", "split_confidence", "needs_review"],
  "properties": {
    "file_id": { "type": "string" },
    "route_type": {
      "type": "string",
      "enum": ["uniform_exam", "free_layout_homework"]
    },
    "question_no": { "type": "string" },
    "page_no": { "type": "integer", "minimum": 1 },
    "block_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "text": { "type": "string" },
    "split_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "needs_review": { "type": "boolean" },
    "start_block_id": { "type": "string" },
    "end_block_id": { "type": "string" },
    "start_anchor_bbox": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "end_anchor_bbox": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "page_height": { "type": "integer", "minimum": 1 },
    "issue_flags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
